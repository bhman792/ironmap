# ============================================================
#  IronMap — Environment Variables
#  Copy this file to .env and fill in your values
#  Never commit .env to version control
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Strong password for PostgreSQL
DB_PASSWORD=change_me_to_something_strong

# ── API ───────────────────────────────────────────────────────
# Secret key for JWT token signing — make this long and random
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string

# Your server's local IP address (used for CORS)
UNRAID_IP=192.168.1.100

# ── Renpho (optional) ─────────────────────────────────────────
# Only needed if you want automatic Renpho smart scale sync
RENPHO_EMAIL=your_renpho_account_email
RENPHO_PASSWORD=your_renpho_account_password
